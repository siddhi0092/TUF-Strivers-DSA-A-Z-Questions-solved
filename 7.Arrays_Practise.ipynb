    "#MATRIX ADDITION \n",
    "\n",
    "A = [\n",
    "    [1, 2],\n",
    "    [3, 4]\n",
    "]\n",
    "\n",
    "B = [\n",
    "    [5, 6],\n",
    "    [7, 8]\n",
    "]\n",
    "\n",
    "result = [\n",
    "    [A[i][j] + B[i][j] for j in range(2)]\n",
    "    for i in range(2)\n",
    "]\n",
    "\n",
    "print(\"Addition Result:\")\n",
    "for row in result:\n",
    "    print(row)\n"
   ]
